# Auto-detect text files and normalize line endings
* text=auto

# Python
*.py text eol=lf

# Shell / scripting
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf

# Documentation / config
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# C/C++ (for JUCE scaffold and plugin bridge)
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.aif binary
*.aiff binary
*.mp3 binary
*.flac binary

# Python build/test artifacts
*.pyc binary
*.pyo binary
*.pyd binary

# Build outputs
*.o binary
*.obj binary
*.a binary
*.lib binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
