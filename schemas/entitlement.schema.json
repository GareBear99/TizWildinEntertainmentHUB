{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entitlement",
  "type": "object",
  "required": [
    "accountId",
    "ownsEveryVST",
    "ownedProducts",
    "ownedBundles",
    "extraSeatQuantity"
  ],
  "properties": {
    "accountId": {
      "type": "string"
    },
    "ownsEveryVST": {
      "type": "boolean"
    },
    "ownedProducts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ownedBundles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extraSeatQuantity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "billingState": {
      "type": "string"
    }
  }
}